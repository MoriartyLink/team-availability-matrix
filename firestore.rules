rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connectivity check path
    match /test/connection {
      allow read: if true;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.keys().size() >= 4 &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email == request.auth.token.email &&
             data.role is string && data.role.size() < 100 &&
             (!data.keys().hasAny(['isAdmin'])) &&
             data.createdAt == request.time;
    }

    function isValidAvailability(data) {
      return data.keys().hasAll(['userId', 'date', 'startTime', 'duration', 'type', 'groupId']) &&
             data.userId == request.auth.uid &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.startTime is number && data.startTime >= 0 && data.startTime < 1440 &&
             data.duration is number && data.duration > 0 && data.duration <= 1440 &&
             data.type in ['free', 'busy'] &&
             data.createdAt == request.time;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // We might restrict this later to groups
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().email == existing().email &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'groupId', 'groupName', 'avatar', 'updatedAt']);
      allow delete: if isOwner(userId);
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().name is string && incoming().name.size() > 0;
      // Admins logic omitted as not requested, but restricted to signed-in users
    }

    match /availability/{slotId} {
      allow list: if isSignedIn(); 
      // Query enforcer: must filter by groupId or userId in production code
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidAvailability(incoming());
      allow update: if isOwner(existing().userId) && 
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['date', 'startTime', 'duration', 'type', 'updatedAt']) &&
                      isValidAvailability(incoming().concat({'createdAt': existing().createdAt})); 
                      // Note: isValidAvailability checks createdAt, so we merge
      allow delete: if isOwner(existing().userId);
    }
  }
}
